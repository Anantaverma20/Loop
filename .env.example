# ── InsForge ──────────────────────────────────────────────────────────────────
# Get these from your InsForge dashboard → Project Settings → API
INSFORGE_URL=https://YOUR_PROJECT_ID.insforge.dev
INSFORGE_ANON_KEY=your-anon-public-key
INSFORGE_SERVICE_KEY=your-service-role-key

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Nia MCP ────────────────────────────────────────────────────────────────────
# Get from https://trynia.ai/dashboard
NIA_API_KEY=nia_...
NIA_INDEX_ID=your-index-id
